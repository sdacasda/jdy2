# JDCloud Athena AX6600 / RE-CS-02
# DAED dashboard + integrated kernel BTF

CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

# Different branches may generate one of these two device symbols.
# make defconfig keeps the valid symbol and discards the invalid one.
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y

CONFIG_TARGET_PER_DEVICE_ROOTFS=y
# CONFIG_TARGET_MULTI_PROFILE is not set
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_DWARVES=y
CONFIG_BPF_TOOLCHAIN_HOST=y
CONFIG_BPF_TOOLCHAIN_HOST_PATH=""
# CONFIG_BPF_TOOLCHAIN_NONE is not set
CONFIG_USE_LLVM_HOST=y
# CONFIG_USE_LLVM_PREBUILT is not set
# CONFIG_USE_LLVM_BUILD is not set

CONFIG_KERNEL_BPF_EVENTS=y
CONFIG_KERNEL_BPF_STREAM_PARSER=y
CONFIG_KERNEL_CGROUP_BPF=y
# RE-CS-02 has a fixed 6144 KiB kernel slot. Keep DWARF/BTF out of the
# boot kernel and supply detached BTF from the root filesystem.
# CONFIG_KERNEL_DEBUG_INFO is not set
# CONFIG_KERNEL_DEBUG_INFO_BTF is not set
# CONFIG_KERNEL_DEBUG_INFO_BTF_MODULES is not set
# CONFIG_KERNEL_MODULE_ALLOW_BTF_MISMATCH is not set

CONFIG_KERNEL_KALLSYMS=y
CONFIG_KERNEL_FTRACE=y
CONFIG_KERNEL_KPROBES=y
CONFIG_KERNEL_KPROBE_EVENTS=y
CONFIG_KERNEL_PERF_EVENTS=y
CONFIG_KERNEL_XDP_SOCKETS=y

CONFIG_PACKAGE_kmod-sched-core=y
CONFIG_PACKAGE_kmod-sched-bpf=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-xdp-sockets-diag=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-tun=y

CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y
CONFIG_PACKAGE_daed=y
# CONFIG_DAED_USE_KERNEL_BTF is not set
CONFIG_DAED_USE_VMLINUX_BTF=y
CONFIG_PACKAGE_vmlinux-btf=y
CONFIG_PACKAGE_luci-app-daede=y
CONFIG_PACKAGE_luci-app-daede_daed=y
# CONFIG_PACKAGE_luci-app-daede_dae is not set
# CONFIG_PACKAGE_dae is not set

CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_firewall4=y
CONFIG_LUCI_LANG_zh_Hans=y

CONFIG_PACKAGE_luci-app-athena-led=y
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_luci-app-wireless-regdb=y

CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y
CONFIG_PACKAGE_kmod-qca-nss-drv-bridge-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vlan-mgr=y
# CONFIG_PACKAGE_kmod-qca-nss-ecm is not set
# The VIKINGYFY router profile installs kmod-nft-offload by default.
# The module may remain installed; runtime flow offload is forced off.
# CONFIG_PACKAGE_kmod-nft-fullcone is not set

CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_gdisk=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_tune2fs=y

CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_dmesg=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_luci-app-ttyd=y

# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-passwall2 is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-homeproxy is not set
# CONFIG_PACKAGE_luci-app-mosdns is not set
# CONFIG_PACKAGE_luci-app-smartdns is not set
# CONFIG_PACKAGE_luci-app-adguardhome is not set
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
